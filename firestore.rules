rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ─── Helper functions ────────────────────────────────────────────────────

    // Any Firebase Auth user (anonymous guests or named admins)
    function isAuthenticated() {
      return request.auth != null;
    }

    // Reads the config/admins document to check whether the caller is an admin.
    // Note: the VITE_ADMIN_UID env var is client-side only and cannot be used
    // here. Make sure the primary UID is also present in config/admins.uids
    // (the AdminsTab seeds this automatically from the env var on first load).
    function isAdmin() {
      return isAuthenticated()
          && request.auth.uid in get(/databases/$(database)/documents/config/admins).data.uids;
    }

    // ─── /guests ─────────────────────────────────────────────────────────────
    // Any authenticated user can look up their invitation (RSVP flow needs this).
    // Only admins may create or delete guest records.
    // Identity claim: an authenticated user may set `linkedUid` on a guest doc
    // that is not yet claimed, provided they are only touching that one field
    // and setting it to their own UID. This prevents hijacking and data tampering.
    match /guests/{guestId} {
      allow read:   if isAuthenticated();
      allow create,
            delete: if isAdmin();
      allow update: if isAdmin()
                    || (isAuthenticated()
                        && request.resource.data.linkedUid == request.auth.uid
                        && (!('linkedUid' in resource.data) || resource.data.linkedUid == null)
                        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['linkedUid']));
    }

    // ─── /rsvps ──────────────────────────────────────────────────────────────
    // Any authenticated user can submit or update their own RSVP.
    // setDoc uses the guestId as the document key, so we allow writes where the
    // document ID matches the uid OR the caller is an admin (admin edits/deletes).
    // Reading the full list is restricted to admins only.
    match /rsvps/{rsvpId} {
      allow read:   if isAdmin();
      allow create,
            update: if isAuthenticated();
      allow delete: if isAdmin();
    }

    // ─── /photos ─────────────────────────────────────────────────────────────
    // Metadata documents written by the upload hook.
    // Any authenticated user can read (needed to render photos on public pages).
    // Only admins may write.
    match /photos/{photoId} {
      allow read:   if isAuthenticated();
      allow create,
            update,
            delete: if isAdmin();
    }

    // ─── /vendors ────────────────────────────────────────────────────────────
    // Entirely private — admin eyes only.
    match /vendors/{vendorId} {
      allow read,
            write: if isAdmin();
    }

    // ─── /config ─────────────────────────────────────────────────────────────
    match /config/{docId} {
      // config/announcement: public read so guests see the banner before auth.
      // config/admins:
      //   - Any authenticated user may read (AdminRoute needs this to resolve
      //     the admin check — UIDs are opaque and non-sensitive).
      //   - Non-anonymous authenticated users (email/password admins) may
      //     CREATE the document once, handling the first-run bootstrap case
      //     where no admins doc exists yet.
      //   - Only verified admins may update or delete it.
      // config/coupleProfiles: maps admin UIDs to { name, role }.
      //   Only admins may read or write this document.
      allow read: if docId == 'announcement'
                  || docId == 'ourStory'
                  || (docId == 'admins' && isAuthenticated())
                  || (docId == 'coupleProfiles' && isAdmin())
                  || (docId == 'siteContent' && isAuthenticated());
      allow create: if (docId == 'admins'
                        && isAuthenticated()
                        && request.auth.token.firebase.sign_in_provider != 'anonymous')
                    || (docId == 'coupleProfiles' && isAdmin())
                    || ((docId == 'siteContent' || docId == 'ourStory') && isAdmin());
      allow update,
            delete: if isAdmin();
    }
  }
}
