rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ─── Helper functions ────────────────────────────────────────────────────

    // Any Firebase Auth user (anonymous guests or named admins)
    function isAuthenticated() {
      return request.auth != null;
    }

    // Reads the config/admins document to check whether the caller is an admin.
    // Note: the VITE_ADMIN_UID env var is client-side only and cannot be used
    // here. Make sure the primary UID is also present in config/admins.uids
    // (the AdminsTab seeds this automatically from the env var on first load).
    function isAdmin() {
      return isAuthenticated()
          && request.auth.uid in get(/databases/$(database)/documents/config/admins).data.uids;
    }

    // ─── /guests ─────────────────────────────────────────────────────────────
    // Any authenticated user can look up their invitation (RSVP flow needs this).
    // Only admins may create or delete guest records.
    // Identity claim: an authenticated user may set `linkedUid` on any guest doc
    // provided they are only touching that one field and setting it to their own
    // UID. This allows re-linking on a new device (multi-device support) while
    // still preventing tampering with any other fields. Admins can fully reset
    // `linkedUid` to null via the admin dashboard.
    match /guests/{guestId} {
      allow read:   if isAuthenticated();
      allow create,
            delete: if isAdmin();
      allow update: if isAdmin()
                    || (isAuthenticated()
                        && request.resource.data.linkedUid == request.auth.uid
                        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['linkedUid']));
    }

    // ─── /rsvps ──────────────────────────────────────────────────────────────
    // Any authenticated user can submit or update their own RSVP.
    // setDoc uses the guestId as the document key, so we allow writes where the
    // document ID matches the uid OR the caller is an admin (admin edits/deletes).
    // Reading the full list is restricted to admins only.
    match /rsvps/{rsvpId} {
      allow read:   if isAdmin();
      allow create,
            update: if isAuthenticated();
      allow delete: if isAdmin();
    }

    // ─── /photos ─────────────────────────────────────────────────────────────
    // Metadata documents written by the upload hook.
    // Any authenticated user can read (needed to render photos on public pages).
    // Only admins may write.
    match /photos/{photoId} {
      allow read:   if isAuthenticated();
      allow create,
            update,
            delete: if isAdmin();
    }

    // ─── /guestProfiles ───────────────────────────────────────────────────────
    // Selfie + fun-fact profiles for the Who's Who Polaroid Wall.
    // Document ID mirrors the corresponding /guests/{guestId} document.
    // Any authenticated user may read (needed to render the wall).
    // A guest may only write their own profile — verified by checking that the
    // linked guest document's `linkedUid` matches the caller's UID.
    // Admins may delete profiles (e.g. moderation).
    match /guestProfiles/{guestId} {
      allow read:  if isAuthenticated();
      allow create,
           update: if isAuthenticated()
                   && (// Admin writing their own profile (couple's uid as key)
                       (isAdmin() && guestId == request.auth.uid)
                       // Guest writing their own profile via linked guest doc
                       || get(/databases/$(database)/documents/guests/$(guestId)).data.linkedUid == request.auth.uid);
      allow delete: if isAdmin();
    }

    // ─── /posts ──────────────────────────────────────────────────────────────
    // The social gathering posts. Any authenticated user may read public posts
    // and create posts. Authors (by uid) and admins may edit/delete.
    // Private posts (isPrivate: true) are only readable by the author + admins.
    match /posts/{postId} {
      allow read: if isAuthenticated()
                  && (resource.data.isPrivate == false
                      || isAdmin()
                      || request.auth.uid == resource.data.authorUid);
      allow create: if isAuthenticated()
                    && request.resource.data.authorUid == request.auth.uid
                    && request.resource.data.isDeleted == false;
      // Post author / admin: full update.
      // Any authenticated user: may only touch likes[] (like/unlike).
      // Any authenticated user: may only touch commentCount + lastActivityAt
      //   (written by the batch in addComment on behalf of the commenter).
      allow update: if isAuthenticated()
                    && (isAdmin()
                        || request.auth.uid == resource.data.authorUid
                        || request.resource.data.diff(resource.data).affectedKeys().hasOnly(['likes'])
                        || request.resource.data.diff(resource.data).affectedKeys().hasOnly(['commentCount', 'lastActivityAt']));
      allow delete: if isAdmin();

      // ─── /posts/{postId}/comments ─────────────────────────────────────────
      match /comments/{commentId} {
        allow read: if isAuthenticated();
        allow create: if isAuthenticated()
                      && request.resource.data.authorUid == request.auth.uid
                      && request.resource.data.isDeleted == false;
        // Comment author / admin: full update.
        // Any authenticated user: may only touch likes[] (like/unlike a comment).
        allow update: if isAuthenticated()
                      && (isAdmin()
                          || request.auth.uid == resource.data.authorUid
                          || request.resource.data.diff(resource.data).affectedKeys().hasOnly(['likes']));
        allow delete: if isAdmin();
      }
    }

    // ─── /notifications ──────────────────────────────────────────────────────
    // Only the recipient may read their own notifications.
    // Any authenticated user may create a notification (needed for like/comment
    // client-side writes). Only the recipient may update (mark as read).
    match /notifications/{notifId} {
      allow read:   if isAuthenticated()
                    && request.auth.uid == resource.data.recipientUid;
      allow create: if isAuthenticated();
      allow update: if isAuthenticated()
                    && request.auth.uid == resource.data.recipientUid;
      allow delete: if isAuthenticated()
                    && request.auth.uid == resource.data.recipientUid;
    }

    // ─── /mixtape ─────────────────────────────────────────────────────────────
    // Crowdsourced reception playlist. Any authenticated guest can read and
    // create songs. Upvoting (touching upvotes/coupleUpvotes/upvoteCount/score/
    // brideVoted/groomVoted) is allowed for any authenticated user.
    // Soft-delete (isDeleted only) is allowed for the requester or an admin.
    // Admins may do any update.
    match /mixtape/{songId} {
      allow read:   if isAuthenticated();
      allow create: if isAuthenticated()
                    && request.resource.data.requestedByUid == request.auth.uid
                    && request.resource.data.isDeleted == false;
      allow update: if isAuthenticated()
                    && (
                      // Admins may do anything
                      isAdmin()
                      // Any authenticated user may toggle their upvote
                      || request.resource.data.diff(resource.data).affectedKeys()
                           .hasOnly(['upvotes', 'upvoteCount', 'score'])
                      // Couple members may also touch coupleUpvotes + role booleans
                      || (isAdmin()
                          && request.resource.data.diff(resource.data).affectedKeys()
                               .hasOnly(['upvotes', 'coupleUpvotes', 'upvoteCount', 'score', 'brideVoted', 'groomVoted']))
                      // Author or admin may soft-delete
                      || ((resource.data.requestedByUid == request.auth.uid || isAdmin())
                          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['isDeleted']))
                    );
      allow delete: if false; // soft-delete only

      // Comments subcollection
      match /comments/{commentId} {
        allow read:   if isAuthenticated();
        allow create: if isAuthenticated()
                      && request.resource.data.authorUid == request.auth.uid
                      && request.resource.data.isDeleted == false;
        allow update: if isAuthenticated()
                      && (
                        isAdmin()
                        // Author may edit content
                        || (resource.data.authorUid == request.auth.uid
                            && request.resource.data.diff(resource.data).affectedKeys()
                                 .hasOnly(['content', 'editedAt']))
                        // Anyone may like/unlike
                        || request.resource.data.diff(resource.data).affectedKeys().hasOnly(['likes'])
                        // Author or admin may soft-delete
                        || ((resource.data.authorUid == request.auth.uid || isAdmin())
                            && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['isDeleted']))
                      );
        allow delete: if false;
      }
    }

    // ─── /vendors ────────────────────────────────────────────────────────────
    // Entirely private — admin eyes only.
    match /vendors/{vendorId} {
      allow read,
            write: if isAdmin();
    }

    // ─── /config ─────────────────────────────────────────────────────────────
    match /config/{docId} {
      // config/announcement: public read so guests see the banner before auth.
      // config/admins:
      //   - Any authenticated user may read (AdminRoute needs this to resolve
      //     the admin check — UIDs are opaque and non-sensitive).
      //   - Non-anonymous authenticated users (email/password admins) may
      //     CREATE the document once, handling the first-run bootstrap case
      //     where no admins doc exists yet.
      //   - Only verified admins may update or delete it.
      // config/coupleProfiles: maps admin UIDs to { name, role }.
      //   Only admins may read or write this document.
      allow read: if docId == 'announcement'
                  || docId == 'ourStory'
                  || (docId == 'admins' && isAuthenticated())
                  || (docId == 'coupleProfiles' && isAdmin())
                  || (docId == 'siteContent' && isAuthenticated());
      allow create: if (docId == 'admins'
                        && isAuthenticated()
                        && request.auth.token.firebase.sign_in_provider != 'anonymous')
                    || (docId == 'coupleProfiles' && isAdmin())
                    || ((docId == 'siteContent' || docId == 'ourStory') && isAdmin());
      allow update,
            delete: if isAdmin();
    }
  }
}
