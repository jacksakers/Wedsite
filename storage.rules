rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {

    // ─── Helper functions ────────────────────────────────────────────────────

    function isAuthenticated() {
      return request.auth != null;
    }

    // Checks config/admins in Firestore. The firestore() function is available
    // in Storage rules (rules_version '2' required).
    function isAdmin() {
      return isAuthenticated()
          && request.auth.uid in firestore.get(
               /databases/(default)/documents/config/admins
             ).data.uids;
    }

    // ─── /selfies ─────────────────────────────────────────────────────────────
    // Guest selfies for the Who's Who Polaroid Wall.
    // Stored under selfies/{guestId}/{filename} so ownership can be verified
    // by looking up the matching guest document in Firestore.
    // Any authenticated user may read (needed to render the wall).
    // A guest may only upload/delete their own selfie.
    // Files must be images and no larger than 10 MB.
    match /selfies/{guestId}/{filename} {
      allow read:   if isAuthenticated();
      allow create: if isAuthenticated()
                    && request.resource.size        <= 10 * 1024 * 1024
                    && request.resource.contentType.matches('image/.*')
                    && (// Admin (couple) uploading their own selfie
                        (isAdmin() && guestId == request.auth.uid)
                        // Guest uploading their own selfie via linked guest doc
                        || request.auth.uid == firestore.get(
                             /databases/(default)/documents/guests/$(guestId)
                           ).data.linkedUid);
      allow delete: if isAuthenticated()
                    && ((isAdmin() && guestId == request.auth.uid)
                        || isAdmin()
                        || request.auth.uid == firestore.get(
                               /databases/(default)/documents/guests/$(guestId)
                             ).data.linkedUid);
      allow update: if false;
    }

    // ─── /postPhotos ──────────────────────────────────────────────────────────
    // Photos attached to social posts. Any authenticated user may read (needed
    // to render photos in the Lounge). Any authenticated user may upload their
    // own post photos. Only admins or the uploader may delete.
    // Files must be images and no larger than 15 MB.
    match /postPhotos/{filename} {
      allow read:   if isAuthenticated();
      allow create: if isAuthenticated()
                    && request.resource.size        <= 15 * 1024 * 1024
                    && request.resource.contentType.matches('image/.*');
      allow delete: if isAdmin();
      allow update: if false;
    }

    // ─── /photos ─────────────────────────────────────────────────────────────
    // Only admins may upload or delete couple photos.
    // Any authenticated user may read (needed to render photo URLs in the app).
    // Files must be images and no larger than 15 MB.
    match /photos/{filename} {
      allow read:   if isAuthenticated();
      allow create: if isAdmin()
                    && request.resource.size   <= 15 * 1024 * 1024
                    && request.resource.contentType.matches('image/.*');
      allow delete: if isAdmin();
      // Disallow direct in-place updates — delete and re-upload instead.
      allow update: if false;
    }

    // Deny everything else by default.
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
