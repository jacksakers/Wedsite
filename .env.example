# Firebase Configuration — copy this file to .env and fill in your values.
# Get these values from your Firebase project console:
# https://console.firebase.google.com → Project Settings → Your apps → SDK setup and configuration
VITE_FIREBASE_API_KEY=replace_with_your_api_key
VITE_FIREBASE_AUTH_DOMAIN=replace_with_your_project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=replace_with_your_project_id
VITE_FIREBASE_STORAGE_BUCKET=replace_with_your_project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=replace_with_your_sender_id
VITE_FIREBASE_APP_ID=replace_with_your_app_id

# Guest access passcode — share this on your Save the Dates.
# Note: Vite VITE_ vars are bundled client-side; real data security comes from Firestore rules.
VITE_GUEST_PASSCODE=replace_with_your_passcode

# Your Firebase Auth UID — required to access the /admin dashboard.
# To find it: Firebase Console → Authentication → Users → your email → copy the UID.
VITE_ADMIN_UID=replace_with_your_firebase_uid
